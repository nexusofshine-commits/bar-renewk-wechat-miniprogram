/* 全局样式 - 现代奢华风格 */
page {
  --color-bg: #0d0d0d;
  --color-surface: #1a1a1a;
  --color-surface-light: #2a2a2a;
  --color-gold: #d4af37;
  --color-gold-light: #f0d878;
  --color-gold-dark: #b8941f;
  --color-text: #ffffff;
  --color-text-secondary: #a0a0a0;
  --color-text-muted: #666666;
  --color-accent: #c9a227;
  
  background-color: var(--color-bg);
  color: var(--color-text);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

/* 全局容器 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--color-bg) 0%, #0a0a0a 100%);
}

/* 金色渐变文字 */
.text-gradient {
  background: linear-gradient(135deg, var(--color-gold) 0%, var(--color-gold-light) 50%, var(--color-gold) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* 金色边框 */
.border-gold {
  border: 1rpx solid rgba(212, 175, 55, 0.3);
  box-shadow: 0 0 20rpx rgba(212, 175, 55, 0.1);
}

/* 卡片样式 */
.card {
  background: linear-gradient(145deg, var(--color-surface) 0%, var(--color-surface-light) 100%);
  border-radius: 24rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.15);
  box-shadow: 
    0 4rpx 20rpx rgba(0, 0, 0, 0.4),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, var(--color-gold) 0%, var(--color-gold-dark) 100%);
  color: var(--color-bg);
  border-radius: 40rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  box-shadow: 
    0 4rpx 15rpx rgba(212, 175, 55, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.2);
  transition: all 0.3s ease;
}

.btn-primary:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(212, 175, 55, 0.2);
}

.btn-secondary {
  background: transparent;
  color: var(--color-text-secondary);
  border: 2rpx solid var(--color-text-muted);
  border-radius: 40rpx;
  transition: all 0.3s ease;
}

.btn-secondary:active {
  border-color: var(--color-gold);
  color: var(--color-gold);
}

/* TabBar 样式优化 */
.tab-bar {
  background: linear-gradient(180deg, rgba(26, 26, 26, 0.95) 0%, rgba(13, 13, 13, 0.98) 100%);
  border-top: 1rpx solid rgba(212, 175, 55, 0.1);
  backdrop-filter: blur(20rpx);
}

.tab-item {
  position: relative;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.tab-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 3rpx;
  background: var(--color-gold);
  border-radius: 0 0 4rpx 4rpx;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.tab-item.active::before {
  opacity: 1;
}

/* 选中态发光效果 */
.tab-item.active {
  transform: translateY(-4rpx);
}

.tab-item.active .tab-icon {
  filter: drop-shadow(0 0 8rpx rgba(212, 175, 55, 0.5));
}

/* 滚动条样式 */
::-webkit-scrollbar {
  width: 4rpx;
}

::-webkit-scrollbar-track {
  background: var(--color-surface);
}

::-webkit-scrollbar-thumb {
  background: var(--color-gold-dark);
  border-radius: 2rpx;
}

/* 动画效果 */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

.animate-fade-in {
  animation: fadeIn 0.6s ease-out;
}

/* 输入框样式 */
.input-elegant {
  background: rgba(42, 42, 42, 0.8);
  border: 1rpx solid rgba(212, 175, 55, 0.2);
  border-radius: 16rpx;
  color: var(--color-text);
  transition: all 0.3s ease;
}

.input-elegant:focus {
  border-color: var(--color-gold);
  box-shadow: 0 0 0 2rpx rgba(212, 175, 55, 0.1);
}

/* 标签样式 */
.tag {
  background: rgba(212, 175, 55, 0.1);
  border: 1rpx solid rgba(212, 175, 55, 0.3);
  border-radius: 30rpx;
  color: var(--color-gold);
  font-size: 24rpx;
  padding: 8rpx 20rpx;
}

.tag.active {
  background: linear-gradient(135deg, var(--color-gold) 0%, var(--color-gold-dark) 100%);
  color: var(--color-bg);
  border-color: transparent;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(212, 175, 55, 0.3) 50%, transparent 100%);
}

/* 价格标签 */
.price-tag {
  background: linear-gradient(135deg, rgba(212, 175, 55, 0.15) 0%, rgba(212, 175, 55, 0.05) 100%);
  border: 1rpx solid rgba(212, 175, 55, 0.3);
  border-radius: 12rpx;
  color: var(--color-gold);
  font-weight: 600;
  padding: 8rpx 16rpx;
}

/* 毛玻璃效果 */
.glass {
  background: rgba(26, 26, 26, 0.7);
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

/* 悬浮效果 */
.hover-lift {
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.hover-lift:active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.3);
}
