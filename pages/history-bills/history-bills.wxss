.container {
  height: calc(100vh - 100rpx);
  display: flex;
  flex-direction: column;
  padding: 20rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #0d0d0d 0%, #1a1a1a 50%, #0d0d0d 100%);
  position: relative;
}

.container::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(ellipse at 50% 0%, rgba(212, 175, 55, 0.03) 0%, transparent 50%);
  pointer-events: none;
}

.page-header {
  flex-shrink: 0;
  padding: 20rpx 0 30rpx;
  text-align: center;
  position: relative;
  z-index: 1;
}

.page-title {
  font-size: 48rpx;
  font-weight: 300;
  letter-spacing: 4rpx;
  background: linear-gradient(135deg, #d4af37 0%, #f0d878 50%, #d4af37 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.bills-list {
  flex: 1;
  position: relative;
  z-index: 1;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #666;
  letter-spacing: 2rpx;
}

.bill-item {
  padding: 28rpx;
  margin-bottom: 20rpx;
  background: linear-gradient(145deg, rgba(42, 42, 42, 0.8) 0%, rgba(26, 26, 26, 0.6) 100%);
  border-radius: 24rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.1);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.bill-item:active {
  border-color: rgba(212, 175, 55, 0.3);
  transform: translateY(2rpx);
}

.bill-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 4rpx;
  height: 100%;
  background: linear-gradient(180deg, #d4af37, transparent);
  opacity: 0.3;
}

.bill-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
}

.bill-date {
  font-size: 32rpx;
  color: #fff;
  font-weight: 500;
  letter-spacing: 1rpx;
}

.bill-count {
  font-size: 26rpx;
  color: #d4af37;
  padding: 8rpx 20rpx;
  background: rgba(212, 175, 55, 0.1);
  border-radius: 20rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.2);
}

.bill-preview {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
}

.bill-items {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.bill-item-name {
  font-size: 26rpx;
  color: #a0a0a0;
}

.more-text {
  font-size: 24rpx;
  color: #666;
  margin-left: 8rpx;
}

.bill-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0 0 16rpx;
  border-top: 1rpx solid rgba(212, 175, 55, 0.1);
}

.bill-revenue {
  font-size: 36rpx;
  color: #d4af37;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.view-detail {
  font-size: 24rpx;
  color: #666;
  letter-spacing: 1rpx;
}
