<view class="container">
  <view class="result-content">
    <view class="cocktail-card">
      <view class="cocktail-icon-wrapper">
        <view class="cup-display">
          <image src="" mode="aspectFit" class="cup-image" />
        </view>
      </view>
      <view class="cocktail-name">{{currentCocktail.name}}</view>
      <view class="cocktail-name-en">{{currentCocktail.name_en}}</view>
      <view class="volume-display">{{currentCocktail.volume}}</view>
      <view class="cocktail-description">{{currentCocktail.description}}</view>
      
      <view class="cocktail-radar">
        <view class="radar-container">
          <canvas 
            type="2d" 
            id="radarCanvas" 
            class="radar-canvas"
          ></canvas>
        </view>
      </view>
      
      <view class="cocktail-price">
        {{cocktailPrice}}
      </view>
    </view>

    <view class="alternatives-section" wx:if="{{showAlternatives}}">
      <view class="alternatives-title">其他推荐</view>
      <view class="alternatives-list">
        <view 
          class="alternative-item" 
          wx:for="{{alternatives}}" 
          wx:key="id"
          data-index="{{item.index}}"
          bindtap="selectAlternative"
        >
          <view class="alternative-mini-cup">
            <image src="" mode="aspectFit" class="mini-cup-image" />
          </view>
          <view class="alternative-details">
            <view class="alternative-name">{{item.cocktail.name}} - {{item.cocktail.name_en}}</view>
            <view class="alternative-description">{{item.cocktail.description}}</view>
          </view>
        </view>
      </view>
    </view>

    <view class="result-actions">
      <button 
        class="btn btn-secondary" 
        wx:if="{{showReroll}}" 
        bindtap="reroll"
      >换一换口味</button>
      <button class="btn btn-primary" bindtap="startOver">重新选择</button>
    </view>
  </view>
</view>
