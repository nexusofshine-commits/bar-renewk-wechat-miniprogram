.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #1a1a1a;
}

.result-header {
  flex-shrink: 0;
  padding: 30rpx 40rpx;
  background: #1a1a1a;
}

.tab-bar {
  display: flex;
  background: #2f2f2f;
  border-radius: 40rpx;
  padding: 8rpx;
  gap: 8rpx;
}

.tab-item {
  flex: 1;
  padding: 20rpx;
  border-radius: 32rpx;
  text-align: center;
  transition: all 0.3s ease;
}

.tab-item.active {
  background: linear-gradient(135deg, #d4af37 0%, #f0c855 100%);
}

.tab-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #808080;
}

.tab-item.active .tab-label {
  color: #1a1a1a;
}

.result-content {
  flex: 1;
  padding: 30rpx;
}

.cocktail-card {
  background: #2f2f2f;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  border: 2rpx solid rgba(212, 175, 55, 0.2);
}

.cocktail-name {
  font-size: 48rpx;
  color: #d4af37;
  text-align: center;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.cocktail-name-en {
  font-size: 28rpx;
  color: #808080;
  text-align: center;
  margin-bottom: 16rpx;
  font-style: italic;
}

.cocktail-volume {
  font-size: 26rpx;
  color: #d4af37;
  text-align: center;
  margin-bottom: 20rpx;
  font-weight: 500;
}

.cocktail-description {
  font-size: 28rpx;
  color: #d0d0d0;
  text-align: center;
  line-height: 1.8;
  margin-bottom: 24rpx;
}

.cocktail-price {
  text-align: center;
  font-size: 36rpx;
  color: #d4af37;
  font-weight: 700;
}

.cocktail-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.cocktail-item {
  padding: 24rpx;
  background: #2f2f2f;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: all 0.3s ease;
}

.cocktail-item.active {
  border-color: #d4af37;
  background: rgba(212, 175, 55, 0.15);
}

.item-name {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 500;
}

.item-price {
  font-size: 26rpx;
  color: #d4af37;
  font-weight: 600;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.action-btn {
  flex: 1;
  padding: 28rpx;
  border-radius: 40rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.3s ease;
}

.action-btn.primary {
  background: linear-gradient(135deg, #d4af37 0%, #f0c855 100%);
  color: #1a1a1a;
}

.action-btn.secondary {
  background: transparent;
  color: #d0d0d0;
  border: 2rpx solid #d0d0d0;
}

.bottom-actions {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

.bottom-btn {
  padding: 20rpx 32rpx;
  font-size: 26rpx;
  color: #808080;
  transition: all 0.3s ease;
}
