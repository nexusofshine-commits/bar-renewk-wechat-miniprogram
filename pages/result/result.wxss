.container {
  padding: 20px;
  max-width: 600px;
  margin: 0 auto;
  min-height: 100vh;
}

.result-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20px;
}

.cocktail-card {
  background: #2f2f2f;
  border-radius: 24px;
  padding: 30px;
  width: 100%;
  border: 1px solid rgba(212, 175, 55, 0.2);
  margin-bottom: 30px;
}

.cocktail-icon-wrapper {
  display: flex;
  justify-content: center;
  margin-bottom: 24px;
}

.cup-display {
  width: 120px;
  height: 168px;
}

.cocktail-name {
  font-size: 2rem;
  color: #d4af37;
  text-align: center;
  margin-bottom: 4px;
}

.cocktail-name-en {
  font-size: 1.1rem;
  color: #808080;
  text-align: center;
  margin-bottom: 20px;
  font-style: italic;
}

.volume-display {
  font-size: 1rem;
  color: #d4af37;
  text-align: center;
  margin-bottom: 20px;
  font-weight: 500;
}

.cocktail-description {
  font-size: 1.05rem;
  color: #d0d0d0;
  text-align: center;
  margin-bottom: 30px;
  line-height: 1.8;
}

.cocktail-radar {
  margin-bottom: 30px;
  display: flex;
  justify-content: center;
}

.radar-container {
  position: relative;
  width: 250px;
  height: 250px;
}

.radar-canvas {
  width: 100%;
  height: 100%;
}

.cocktail-price {
  text-align: center;
  font-size: 1.3rem;
  color: #d4af37;
  font-weight: 700;
  margin-bottom: 30px;
}

.alternatives-section {
  width: 100%;
  margin-top: 20px;
}

.alternatives-title {
  font-size: 1.3rem;
  color: #d4af37;
  margin-bottom: 20px;
  text-align: center;
}

.alternatives-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.alternative-item {
  padding: 20px;
  background: #2f2f2f;
  border-radius: 16px;
  border: 1px solid rgba(212, 175, 55, 0.2);
  cursor: pointer;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  gap: 16px;
}

.alternative-mini-cup {
  width: 50px;
  height: 70px;
  flex-shrink: 0;
}

.alternative-details {
  flex: 1;
}

.alternative-name {
  font-weight: 600;
  color: #d4af37;
  margin-bottom: 4px;
}

.alternative-description {
  font-size: 0.9rem;
  color: #d0d0d0;
}

.result-actions {
  display: flex;
  flex-direction: column;
  gap: 16px;
  width: 100%;
}

.btn {
  padding: 16px 40px;
  font-size: 1.1rem;
  border: none;
  border-radius: 30px;
  cursor: pointer;
  transition: all 0.3s ease;
  font-weight: 600;
  letter-spacing: 0.5px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.btn-primary {
  background: linear-gradient(135deg, #d4af37 0%, #f0c855 100%);
  color: #1a1a1a;
}

.btn-secondary {
  background: transparent;
  color: #d0d0d0;
  border: 2px solid #d0d0d0;
}
