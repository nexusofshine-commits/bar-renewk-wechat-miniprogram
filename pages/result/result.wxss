.container {
  height: calc(100vh - 100rpx);
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #0d0d0d 0%, #1a1a1a 50%, #0d0d0d 100%);
  position: relative;
}

.container::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: 
    radial-gradient(ellipse at 50% 0%, rgba(212, 175, 55, 0.05) 0%, transparent 50%),
    radial-gradient(ellipse at 50% 100%, rgba(212, 175, 55, 0.03) 0%, transparent 50%);
  pointer-events: none;
}

.result-header {
  flex-shrink: 0;
  padding: 30rpx 40rpx;
  position: relative;
  z-index: 1;
}

.tab-bar {
  display: flex;
  background: linear-gradient(145deg, rgba(42, 42, 42, 0.8) 0%, rgba(26, 26, 26, 0.6) 100%);
  border-radius: 40rpx;
  padding: 8rpx;
  gap: 8rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.1);
  box-shadow: 
    0 4rpx 20rpx rgba(0, 0, 0, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
}

.tab-item {
  flex: 1;
  padding: 20rpx;
  border-radius: 32rpx;
  text-align: center;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.tab-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(212, 175, 55, 0.2) 0%, rgba(212, 175, 55, 0.1) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.tab-item.active {
  background: linear-gradient(135deg, #d4af37 0%, #c9a227 50%, #b8941f 100%);
  box-shadow: 0 4rpx 15rpx rgba(212, 175, 55, 0.3);
}

.tab-item.active::before {
  opacity: 1;
}

.tab-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #808080;
  position: relative;
  z-index: 1;
  transition: color 0.3s ease;
}

.tab-item.active .tab-label {
  color: #0d0d0d;
  font-weight: 600;
}

.result-content {
  flex: 1;
  padding: 30rpx;
  position: relative;
  z-index: 1;
}

.cocktail-card {
  background: linear-gradient(145deg, rgba(42, 42, 42, 0.8) 0%, rgba(26, 26, 26, 0.6) 100%);
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  margin-bottom: 30rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.2);
  box-shadow: 
    0 8rpx 40rpx rgba(0, 0, 0, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(10rpx);
  position: relative;
  overflow: hidden;
}

.cocktail-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(212, 175, 55, 0.5), transparent);
}

.cocktail-name {
  font-size: 52rpx;
  font-weight: 300;
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
  background: linear-gradient(135deg, #d4af37 0%, #f0d878 50%, #d4af37 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-align: center;
}

.cocktail-name-en {
  font-size: 26rpx;
  color: #666;
  text-align: center;
  margin-bottom: 20rpx;
  font-style: italic;
  letter-spacing: 2rpx;
}

.cocktail-volume {
  font-size: 24rpx;
  color: #d4af37;
  text-align: center;
  margin-bottom: 24rpx;
  padding: 8rpx 24rpx;
  background: rgba(212, 175, 55, 0.1);
  border-radius: 20rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.2);
  display: inline-block;
}

.cocktail-description {
  font-size: 28rpx;
  color: #a0a0a0;
  text-align: center;
  line-height: 1.8;
  margin-bottom: 28rpx;
  padding: 0 20rpx;
}

.cocktail-price {
  text-align: center;
  font-size: 48rpx;
  font-weight: 300;
  background: linear-gradient(135deg, #d4af37 0%, #f0d878 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 2rpx;
}

.cocktail-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.cocktail-item {
  padding: 28rpx;
  background: linear-gradient(145deg, rgba(42, 42, 42, 0.6) 0%, rgba(26, 26, 26, 0.4) 100%);
  border-radius: 20rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.1);
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.2);
}

.cocktail-item.active {
  border-color: rgba(212, 175, 55, 0.4);
  background: linear-gradient(145deg, rgba(212, 175, 55, 0.15) 0%, rgba(212, 175, 55, 0.05) 100%);
  box-shadow: 
    0 0 25rpx rgba(212, 175, 55, 0.15),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  transform: translateX(8rpx);
}

.item-name {
  font-size: 30rpx;
  color: #fff;
  font-weight: 400;
  letter-spacing: 1rpx;
}

.item-price {
  font-size: 28rpx;
  color: #d4af37;
  font-weight: 500;
  padding: 8rpx 20rpx;
  background: rgba(212, 175, 55, 0.1);
  border-radius: 16rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.2);
}

.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.action-btn {
  flex: 1;
  padding: 32rpx;
  border-radius: 40rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.action-btn.primary {
  background: linear-gradient(135deg, #d4af37 0%, #c9a227 50%, #b8941f 100%);
  color: #0d0d0d;
  box-shadow: 
    0 8rpx 30rpx rgba(212, 175, 55, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.3);
}

.action-btn.primary:active {
  transform: translateY(2rpx) scale(0.98);
  box-shadow: 0 4rpx 15rpx rgba(212, 175, 55, 0.2);
}

.action-btn.secondary {
  background: transparent;
  color: #a0a0a0;
  border: 2rpx solid rgba(160, 160, 160, 0.3);
}

.action-btn.secondary:active {
  border-color: #d4af37;
  color: #d4af37;
  background: rgba(212, 175, 55, 0.05);
}

.bottom-actions {
  display: flex;
  gap: 20rpx;
  justify-content: center;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(212, 175, 55, 0.1);
}

.bottom-btn {
  padding: 20rpx 40rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.3s ease;
  position: relative;
}

.bottom-btn::after {
  content: '';
  position: absolute;
  bottom: 10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 2rpx;
  background: #d4af37;
  transition: width 0.3s ease;
}

.bottom-btn:active {
  color: #d4af37;
}

.bottom-btn:active::after {
  width: 60%;
}
