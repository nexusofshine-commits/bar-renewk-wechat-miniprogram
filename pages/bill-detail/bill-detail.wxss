.container {
  height: calc(100vh - 100rpx);
  display: flex;
  flex-direction: column;
  padding: 20rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #0d0d0d 0%, #1a1a1a 50%, #0d0d0d 100%);
  position: relative;
}

.container::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(ellipse at 50% 0%, rgba(212, 175, 55, 0.03) 0%, transparent 50%);
  pointer-events: none;
}

.page-header {
  flex-shrink: 0;
  padding: 20rpx 0 30rpx;
  text-align: center;
  position: relative;
  z-index: 1;
}

.page-title {
  font-size: 48rpx;
  font-weight: 300;
  letter-spacing: 4rpx;
  background: linear-gradient(135deg, #d4af37 0%, #f0d878 50%, #d4af37 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.bill-summary {
  flex-shrink: 0;
  display: flex;
  justify-content: space-around;
  padding: 30rpx 20rpx;
  margin-bottom: 20rpx;
  background: linear-gradient(145deg, rgba(42, 42, 42, 0.8) 0%, rgba(26, 26, 26, 0.6) 100%);
  border-radius: 24rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.2);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
  position: relative;
  z-index: 1;
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 12rpx;
  letter-spacing: 1rpx;
}

.summary-value {
  font-size: 32rpx;
  color: #fff;
  font-weight: 500;
}

.summary-value.highlight {
  color: #d4af37;
  font-size: 36rpx;
  font-weight: 600;
}

.orders-list {
  flex: 1;
  position: relative;
  z-index: 1;
}

.orders-title {
  font-size: 28rpx;
  color: #d4af37;
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
  padding-left: 8rpx;
}

.order-item {
  padding: 24rpx;
  margin-bottom: 16rpx;
  background: linear-gradient(145deg, rgba(42, 42, 42, 0.8) 0%, rgba(26, 26, 26, 0.6) 100%);
  border-radius: 20rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.1);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
  position: relative;
  overflow: hidden;
}

.order-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 3rpx;
  height: 100%;
  background: linear-gradient(180deg, #d4af37, transparent);
  opacity: 0.3;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-left: 12rpx;
}

.order-time {
  font-size: 22rpx;
  color: #666;
  letter-spacing: 1rpx;
}

.order-badge {
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, rgba(212, 175, 55, 0.2) 0%, rgba(212, 175, 55, 0.1) 100%);
  color: #d4af37;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: 500;
  border: 1rpx solid rgba(212, 175, 55, 0.3);
}

.order-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-left: 12rpx;
}

.order-info {
  flex: 1;
}

.cocktail-name {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
  margin-bottom: 6rpx;
  letter-spacing: 1rpx;
}

.cocktail-name-en {
  font-size: 22rpx;
  color: #666;
  font-style: italic;
}

.order-price {
  font-size: 30rpx;
  color: #d4af37;
  font-weight: 600;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0 0 12rpx;
  border-top: 1rpx solid rgba(212, 175, 55, 0.1);
}

.user-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(212, 175, 55, 0.3);
}

.avatar-placeholder {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  background: rgba(212, 175, 55, 0.1);
  border-radius: 50%;
  border: 2rpx solid rgba(212, 175, 55, 0.2);
}

.user-name {
  font-size: 24rpx;
  color: #a0a0a0;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #666;
  letter-spacing: 2rpx;
}
