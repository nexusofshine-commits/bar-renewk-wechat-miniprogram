<view class="container">
  <view class="progress-bar">
    <view class="progress-steps">
      <view 
        class="step-indicator {{currentStep === 1 ? 'active' : currentStep > 1 ? 'completed' : ''}}"
      >1</view>
      <view class="step-line"></view>
      <view 
        class="step-indicator {{currentStep === 2 ? 'active' : currentStep > 2 ? 'completed' : ''}}"
      >2</view>
      <view class="step-line"></view>
      <view 
        class="step-indicator {{currentStep === 3 ? 'active' : ''}}"
      >3</view>
    </view>
  </view>

  <view class="step-content">
    <view class="step-header">
      <view class="step-title">{{selectionFlow[currentStep - 1].title}}</view>
      <view class="step-subtitle">{{selectionFlow[currentStep - 1].subtitle}}</view>
    </view>

    <view wx:if="{{currentStep === 1}}" class="step-1-layout">
      <view 
        wx:for="{{selectionFlow[0].options}}" 
        wx:key="id"
        class="base-option {{selections.base === item.id ? 'selected' : ''}}"
        data-option-id="{{item.id}}"
        bindtap="selectBase"
      >
        <view class="base-icon">{{item.icon}}</view>
        <view class="base-label">{{item.label}}</view>
        <view class="base-description">{{item.description}}</view>
        <view class="base-volume">{{item.volume}}</view>
      </view>
    </view>

    <view wx:if="{{currentStep === 2}}" class="step-2-layout">
      <scroll-view scroll-y class="flavor-scroll">
        <view class="flavor-grid">
          <view 
            wx:for="{{flavorOptions}}" 
            wx:key="id"
            class="flavor-tag {{selections.flavor === item.id ? 'selected' : ''}}"
            data-option-id="{{item.id}}"
            bindtap="selectFlavor"
          >
            <text class="flavor-icon">{{item.icon}}</text>
            <text class="flavor-label">{{item.label}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <view wx:if="{{currentStep === 3}}" class="step-3-layout">
      <view 
        wx:for="{{selectionFlow[2].options}}" 
        wx:key="id"
        class="strength-option {{selections.strength === item.id ? 'selected' : ''}}"
        data-option-id="{{item.id}}"
        bindtap="selectStrength"
      >
        <view class="strength-label">{{item.label}}</view>
        <view class="strength-description">{{item.description}}</view>
      </view>
    </view>
  </view>
</view>
