.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #1a1a1a;
}

.progress-bar {
  flex-shrink: 0;
  padding: 30rpx 40rpx;
  background: #1a1a1a;
}

.progress-steps {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 20rpx;
}

.step-indicator {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #2f2f2f;
  color: #808080;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 28rpx;
  transition: all 0.3s ease;
  border: 4rpx solid transparent;
}

.step-indicator.active {
  background: #d4af37;
  color: #1a1a1a;
  border-color: #f0c855;
}

.step-indicator.completed {
  background: rgba(212, 175, 55, 0.2);
  color: #d4af37;
  border-color: #d4af37;
}

.step-line {
  width: 80rpx;
  height: 4rpx;
  background: #2f2f2f;
}

.step-content {
  flex: 1;
  padding: 0 30rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.step-header {
  flex-shrink: 0;
  text-align: center;
  margin-bottom: 30rpx;
  padding: 20rpx 0;
}

.step-title {
  font-size: 44rpx;
  color: #d4af37;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.step-subtitle {
  font-size: 28rpx;
  color: #d0d0d0;
}

.step-1-layout {
  flex: 1;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  padding: 10rpx 0;
  align-content: start;
}

.base-option {
  padding: 28rpx;
  background: #2f2f2f;
  border-radius: 20rpx;
  border: 4rpx solid transparent;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.3s ease;
}

.base-option.selected {
  border-color: #d4af37;
  background: rgba(212, 175, 55, 0.15);
}

.base-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.base-label {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.base-description {
  font-size: 24rpx;
  color: #808080;
  text-align: center;
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.base-volume {
  font-size: 24rpx;
  color: #d4af37;
  font-weight: 500;
}

.step-2-layout {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.flavor-scroll {
  flex: 1;
  padding: 10rpx 0;
}

.flavor-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  justify-content: center;
  padding: 10rpx 0;
}

.flavor-tag {
  padding: 20rpx 28rpx;
  background: #2f2f2f;
  border-radius: 40rpx;
  border: 4rpx solid transparent;
  display: flex;
  align-items: center;
  gap: 12rpx;
  transition: all 0.3s ease;
}

.flavor-tag.selected {
  border-color: #d4af37;
  background: rgba(212, 175, 55, 0.15);
  color: #d4af37;
}

.flavor-icon {
  font-size: 32rpx;
}

.flavor-label {
  font-size: 28rpx;
  color: #ffffff;
}

.flavor-tag.selected .flavor-label {
  color: #d4af37;
}

.confirm-section {
  flex-shrink: 0;
  padding: 24rpx 0;
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 20rpx;
}

.selected-count {
  flex: 1;
  font-size: 28rpx;
  color: #d0d0d0;
  text-align: center;
}

.confirm-btn {
  padding: 20rpx 50rpx;
  background: linear-gradient(135deg, #d4af37 0%, #f0c855 100%);
  color: #1a1a1a;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.step-3-layout {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 10rpx 0;
}

.strength-option {
  flex: 1;
  padding: 32rpx;
  background: #2f2f2f;
  border-radius: 20rpx;
  border: 4rpx solid transparent;
  display: flex;
  flex-direction: column;
  justify-content: center;
  transition: all 0.3s ease;
}

.strength-option.selected {
  border-color: #d4af37;
  background: rgba(212, 175, 55, 0.15);
}

.strength-label {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.strength-description {
  font-size: 26rpx;
  color: #d0d0d0;
}
