.container {
  height: calc(100vh - 100rpx);
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #0d0d0d 0%, #1a1a1a 50%, #0d0d0d 100%);
  position: relative;
}

.container::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: 
    radial-gradient(ellipse at 20% 30%, rgba(212, 175, 55, 0.03) 0%, transparent 50%),
    radial-gradient(ellipse at 80% 70%, rgba(212, 175, 55, 0.02) 0%, transparent 50%);
  pointer-events: none;
}

.progress-bar {
  flex-shrink: 0;
  padding: 40rpx 60rpx;
  position: relative;
  z-index: 1;
}

.progress-steps {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 30rpx;
}

.step-indicator {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #2a2a2a 0%, #1a1a1a 100%);
  color: #666;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  font-size: 28rpx;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  border: 2rpx solid rgba(212, 175, 55, 0.1);
  box-shadow: 
    0 4rpx 15rpx rgba(0, 0, 0, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
}

.step-indicator.active {
  background: linear-gradient(135deg, #d4af37 0%, #c9a227 50%, #b8941f 100%);
  color: #0d0d0d;
  border-color: transparent;
  box-shadow: 
    0 0 30rpx rgba(212, 175, 55, 0.4),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.3);
  transform: scale(1.1);
}

.step-indicator.completed {
  background: rgba(212, 175, 55, 0.15);
  color: #d4af37;
  border-color: rgba(212, 175, 55, 0.5);
}

.step-line {
  width: 80rpx;
  height: 2rpx;
  background: linear-gradient(90deg, rgba(212, 175, 55, 0.3), rgba(212, 175, 55, 0.1));
  position: relative;
}

.step-line::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, #d4af37, transparent);
  transform: translateY(-50%);
  opacity: 0.5;
}

.step-content {
  flex: 1;
  padding: 0 40rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  position: relative;
  z-index: 1;
}

.step-header {
  flex-shrink: 0;
  text-align: center;
  margin-bottom: 40rpx;
  padding: 20rpx 0;
}

.step-title {
  font-size: 48rpx;
  font-weight: 300;
  letter-spacing: 4rpx;
  margin-bottom: 16rpx;
  background: linear-gradient(135deg, #d4af37 0%, #f0d878 50%, #d4af37 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.step-subtitle {
  font-size: 26rpx;
  color: #808080;
  letter-spacing: 2rpx;
  font-weight: 300;
}

.step-1-layout {
  flex: 1;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  padding: 10rpx 0;
  align-content: start;
}

.base-option {
  padding: 32rpx 24rpx;
  background: linear-gradient(145deg, rgba(42, 42, 42, 0.8) 0%, rgba(26, 26, 26, 0.6) 100%);
  border-radius: 24rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.1);
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 
    0 4rpx 20rpx rgba(0, 0, 0, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(10rpx);
}

.base-option.selected {
  border-color: rgba(212, 175, 55, 0.5);
  background: linear-gradient(145deg, rgba(212, 175, 55, 0.15) 0%, rgba(212, 175, 55, 0.05) 100%);
  box-shadow: 
    0 0 30rpx rgba(212, 175, 55, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  transform: translateY(-4rpx);
}

.base-icon {
  font-size: 72rpx;
  margin-bottom: 20rpx;
  filter: drop-shadow(0 4rpx 8rpx rgba(0, 0, 0, 0.3));
}

.base-label {
  font-size: 32rpx;
  font-weight: 500;
  color: #fff;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.base-description {
  font-size: 22rpx;
  color: #808080;
  text-align: center;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.base-volume {
  font-size: 22rpx;
  color: #d4af37;
  font-weight: 500;
  padding: 6rpx 16rpx;
  background: rgba(212, 175, 55, 0.1);
  border-radius: 20rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.2);
}

.step-2-layout {
  flex: 1;
  padding: 10rpx 0;
}

.flavor-scroll {
  height: 100%;
}

.flavor-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  justify-content: center;
}

.flavor-tag {
  padding: 24rpx 32rpx;
  background: linear-gradient(145deg, rgba(42, 42, 42, 0.8) 0%, rgba(26, 26, 26, 0.6) 100%);
  border-radius: 40rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.1);
  display: flex;
  align-items: center;
  gap: 12rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 
    0 4rpx 15rpx rgba(0, 0, 0, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
}

.flavor-tag.selected {
  border-color: rgba(212, 175, 55, 0.5);
  background: linear-gradient(135deg, rgba(212, 175, 55, 0.2) 0%, rgba(212, 175, 55, 0.1) 100%);
  box-shadow: 
    0 0 20rpx rgba(212, 175, 55, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  transform: scale(1.05);
}

.flavor-icon {
  font-size: 36rpx;
}

.flavor-label {
  font-size: 28rpx;
  color: #d0d0d0;
  font-weight: 400;
}

.flavor-tag.selected .flavor-label {
  color: #d4af37;
  font-weight: 500;
}

.step-3-layout {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 10rpx 0;
}

.strength-option {
  flex: 1;
  padding: 40rpx;
  background: linear-gradient(145deg, rgba(42, 42, 42, 0.8) 0%, rgba(26, 26, 26, 0.6) 100%);
  border-radius: 24rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.1);
  display: flex;
  flex-direction: column;
  justify-content: center;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 
    0 4rpx 20rpx rgba(0, 0, 0, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(10rpx);
}

.strength-option.selected {
  border-color: rgba(212, 175, 55, 0.5);
  background: linear-gradient(145deg, rgba(212, 175, 55, 0.15) 0%, rgba(212, 175, 55, 0.05) 100%);
  box-shadow: 
    0 0 30rpx rgba(212, 175, 55, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  transform: translateY(-4rpx);
}

.strength-label {
  font-size: 40rpx;
  font-weight: 500;
  color: #fff;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.strength-description {
  font-size: 26rpx;
  color: #808080;
  line-height: 1.6;
}
