.container {
  height: calc(100vh - 100rpx);
  display: flex;
  flex-direction: column;
  padding: 20rpx;
  box-sizing: border-box;
  background: #1a1a1a;
}

.search-section {
  flex-shrink: 0;
  padding: 10rpx 0;
}

.search-input {
  width: 100%;
  padding: 20rpx 30rpx;
  background: #2f2f2f;
  border-radius: 30rpx;
  color: #ffffff;
  font-size: 28rpx;
}

.search-input::placeholder {
  color: #808080;
}

.tab-bar {
  flex-shrink: 0;
  display: flex;
  gap: 16rpx;
  padding: 10rpx 0;
  overflow-x: auto;
}

.tab-bar::-webkit-scrollbar {
  display: none;
}

.tab-item {
  padding: 16rpx 32rpx;
  background: #2f2f2f;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #808080;
  flex-shrink: 0;
  transition: all 0.3s ease;
}

.tab-item.active {
  background: #d4af37;
  color: #1a1a1a;
}

.cocktail-list {
  flex: 1;
  padding: 10rpx 0;
}

.cocktail-item {
  padding: 24rpx;
  margin-bottom: 16rpx;
  background: #2f2f2f;
  border-radius: 16rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.2);
}

.cocktail-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.cocktail-name-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.cocktail-name {
  font-size: 32rpx;
  color: #d4af37;
  font-weight: 600;
}

.cocktail-name-en {
  font-size: 24rpx;
  color: #808080;
  font-style: italic;
}

.cocktail-description {
  font-size: 26rpx;
  color: #d0d0d0;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.cocktail-meta {
  display: flex;
  gap: 20rpx;
  margin-top: 8rpx;
}

.cocktail-volume {
  font-size: 24rpx;
  color: #d4af37;
}

.cocktail-price {
  font-size: 26rpx;
  color: #d4af37;
  font-weight: 600;
}

.special-order-btn {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  margin-top: 20rpx;
  background: linear-gradient(135deg, #d4af37 0%, #f0c855 100%);
  border-radius: 40rpx;
}

.special-icon {
  font-size: 32rpx;
}

.special-text {
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 600;
}
