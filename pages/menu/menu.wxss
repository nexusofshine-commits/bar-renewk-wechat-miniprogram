.container {
  height: calc(100vh - 100rpx);
  display: flex;
  flex-direction: column;
  padding: 20rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #0d0d0d 0%, #1a1a1a 50%, #0d0d0d 100%);
  position: relative;
}

.container::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(ellipse at 50% 0%, rgba(212, 175, 55, 0.03) 0%, transparent 50%);
  pointer-events: none;
}

.search-section {
  flex-shrink: 0;
  padding: 10rpx 0;
  position: relative;
  z-index: 1;
}

.search-input {
  width: 100%;
  padding: 24rpx 32rpx;
  background: linear-gradient(145deg, rgba(42, 42, 42, 0.8) 0%, rgba(26, 26, 26, 0.6) 100%);
  border-radius: 40rpx;
  color: #fff;
  font-size: 28rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.1);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
  transition: all 0.3s ease;
}

.search-input:focus {
  border-color: rgba(212, 175, 55, 0.3);
  box-shadow: 0 0 20rpx rgba(212, 175, 55, 0.1);
}

.search-input::placeholder {
  color: #666;
}

.tab-bar {
  flex-shrink: 0;
  display: flex;
  gap: 16rpx;
  padding: 20rpx 0;
  overflow-x: auto;
  position: relative;
  z-index: 1;
}

.tab-bar::-webkit-scrollbar {
  display: none;
}

.tab-item {
  padding: 20rpx 36rpx;
  background: linear-gradient(145deg, rgba(42, 42, 42, 0.6) 0%, rgba(26, 26, 26, 0.4) 100%);
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #808080;
  flex-shrink: 0;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  border: 1rpx solid rgba(212, 175, 55, 0.1);
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.2);
}

.tab-item.active {
  background: linear-gradient(135deg, #d4af37 0%, #c9a227 50%, #b8941f 100%);
  color: #0d0d0d;
  border-color: transparent;
  box-shadow: 0 4rpx 20rpx rgba(212, 175, 55, 0.3);
  font-weight: 500;
}

.cocktail-list {
  flex: 1;
  padding: 10rpx 0;
  position: relative;
  z-index: 1;
}

.cocktail-item {
  padding: 28rpx;
  margin-bottom: 16rpx;
  background: linear-gradient(145deg, rgba(42, 42, 42, 0.8) 0%, rgba(26, 26, 26, 0.6) 100%);
  border-radius: 20rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.1);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
  transition: all 0.3s ease;
}

.cocktail-item:active {
  border-color: rgba(212, 175, 55, 0.3);
  transform: translateX(4rpx);
}

.cocktail-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.cocktail-name-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.cocktail-name {
  font-size: 32rpx;
  color: #d4af37;
  font-weight: 500;
  letter-spacing: 1rpx;
}

.cocktail-name-en {
  font-size: 24rpx;
  color: #666;
  font-style: italic;
}

.cocktail-description {
  font-size: 26rpx;
  color: #a0a0a0;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.cocktail-meta {
  display: flex;
  gap: 20rpx;
  margin-top: 8rpx;
  align-items: center;
}

.cocktail-volume {
  font-size: 24rpx;
  color: #808080;
  padding: 6rpx 16rpx;
  background: rgba(128, 128, 128, 0.1);
  border-radius: 16rpx;
}

.cocktail-price {
  font-size: 28rpx;
  color: #d4af37;
  font-weight: 600;
  padding: 6rpx 20rpx;
  background: rgba(212, 175, 55, 0.1);
  border-radius: 16rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.2);
}

.special-order-btn {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 28rpx;
  margin-top: 20rpx;
  background: linear-gradient(135deg, #d4af37 0%, #c9a227 50%, #b8941f 100%);
  border-radius: 40rpx;
  box-shadow: 0 8rpx 30rpx rgba(212, 175, 55, 0.3);
  transition: all 0.3s ease;
  position: relative;
  z-index: 1;
}

.special-order-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 15rpx rgba(212, 175, 55, 0.2);
}

.special-icon {
  font-size: 36rpx;
}

.special-text {
  font-size: 30rpx;
  color: #0d0d0d;
  font-weight: 600;
  letter-spacing: 2rpx;
}
