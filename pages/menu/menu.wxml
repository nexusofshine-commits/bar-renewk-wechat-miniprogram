<view class="container">
  <view class="search-section">
    <input 
      class="search-input" 
      placeholder="搜索鸡尾酒..." 
      bindinput="onSearch"
      value="{{searchKeyword}}"
    />
  </view>
  
  <view class="tab-bar">
    <view 
      wx:for="{{tabs}}" 
      wx:key="id"
      class="tab-item {{currentTab === item.id ? 'active' : ''}}"
      data-tab-id="{{item.id}}"
      bindtap="switchTab"
    >
      {{item.label}}
    </view>
  </view>
  
  <scroll-view 
    class="cocktail-list" 
    scroll-y 
    enhanced 
    show-scrollbar="{{false}}"
  >
    <view 
      class="cocktail-item" 
      wx:for="{{filteredCocktails}}" 
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="goToResult"
    >
      <view class="cocktail-info">
        <view class="cocktail-name-row">
          <text class="cocktail-name">{{item.name}}</text>
          <text class="cocktail-name-en">{{item.name_en}}</text>
        </view>
        <text class="cocktail-description">{{item.description}}</text>
        <view class="cocktail-meta">
          <text class="cocktail-volume">{{item.volume}}</text>
          <text class="cocktail-price" wx:if="{{item.price}}">¥{{item.price}}</text>
          <text class="cocktail-price" wx:elif="{{item.price_range}}">¥{{Math.round((item.price_range[0]+item.price_range[1])/2)}}</text>
        </view>
      </view>
    </view>
  </scroll-view>
  
  <view class="special-order-btn" bindtap="orderSpecial">
    <text class="special-icon">✨</text>
    <text class="special-text">特调下单 ¥58</text>
  </view>
</view>
