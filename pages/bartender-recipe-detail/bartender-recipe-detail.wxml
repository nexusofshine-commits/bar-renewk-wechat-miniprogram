<view class="container">
  <view class="header">
    <view class="header-title">{{cocktail.name}}</view>
    <view class="header-subtitle">{{cocktail.name_en}}</view>
  </view>

  <view class="section">
    <view class="section-title">基本信息</view>
    <view class="info-card">
      <view class="info-row">
        <view class="info-label">状态</view>
        <view class="info-value">
          <switch checked="{{cocktail.isActive}}" bindchange="toggleStatus" color="#d4af37"/>
        </view>
      </view>
      <view class="info-row">
        <view class="info-label">价格</view>
        <view class="info-value price">¥{{cocktail.price}}</view>
      </view>
      <view class="info-row">
        <view class="info-label">销量</view>
        <view class="info-value">{{cocktail.sales || 0}} 杯</view>
      </view>
      <view class="info-row">
        <view class="info-label">出品杯量</view>
        <view class="info-value">
          <input class="inline-input" 
                 type="digit" 
                 value="{{cocktail.serveSize}}" 
                 bindchange="updateServeSize"
                 placeholder="ml"/>
          <text class="unit-text">ml</text>
        </view>
      </view>
      <view class="info-row highlight">
        <view class="info-label">化水量（自动计算）</view>
        <view class="info-value water">{{calculatedWater}} ml</view>
      </view>
      <view class="info-row highlight">
        <view class="info-label">出品酒精度</view>
        <view class="info-value abv">{{calculatedABV}}%</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">自定义标签</view>
    <view class="tags-section">
      <view class="tags-list">
        <view class="tag-item" wx:for="{{cocktail.tags}}" wx:key="*this">
          <text>{{item}}</text>
          <text class="tag-delete" catchtap="deleteTag" data-index="{{index}}">×</text>
        </view>
      </view>
      <view class="add-tag-section">
        <input class="tag-input" 
               value="{{newTag}}" 
               placeholder="输入标签名称" 
               bindinput="onTagInput"/>
        <button class="tag-add-btn" catchtap="addTag">添加</button>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">材料配方</view>
    <view class="materials-summary">
      <view class="summary-item">
        <text class="summary-label">材料总量：</text>
        <text class="summary-value">{{totalMaterialsVolume}} ml</text>
      </view>
    </view>
    
    <view class="materials-list">
      <view class="material-item" wx:for="{{cocktail.materials}}" wx:key="index">
        <view class="material-name">{{getMaterialName(item.name)}}</view>
        <view class="material-abv" wx:if="{{getMaterialABV(item.name)}}">
          ({{getMaterialABV(item.name)}}%)
        </view>
        <view class="material-amount">
          <input type="digit" 
                 value="{{item.amount}}" 
                 data-index="{{index}}"
                 bindchange="updateMaterialAmount"
                 class="amount-input"/>
          <text class="unit">{{getMaterialUnit(item.name)}}</text>
        </view>
        <button class="delete-btn" catchtap="deleteMaterial" data-index="{{index}}">删除</button>
      </view>
    </view>
    
    <view class="add-material-section">
      <view class="add-material-header" bindtap="toggleMaterialPicker">
        <text class="add-material-text">选择库存材料</text>
        <text class="arrow">{{showMaterialPicker ? '▼' : '▶'}}</text>
      </view>
      
      <view class="material-picker" wx:if="{{showMaterialPicker}}">
        <view class="material-picker-item {{selectedMaterialIndex === index ? 'selected' : ''}}" 
              wx:for="{{availableInventory}}" 
              wx:key="id" 
              catchtap="selectMaterial" 
              data-index="{{index}}">
          <text class="material-picker-text">{{item.name}}</text>
          <text class="material-picker-abv" wx:if="{{item.abv}}">{{item.abv}}%</text>
          <text wx:if="{{selectedMaterialIndex === index}}" class="check-mark">✓</text>
        </view>
        
        <view wx:if="{{selectedMaterialIndex !== -1}}">
          <view class="amount-input-section">
            <text class="label">用量：</text>
            <input type="digit" 
                   class="amount-input-small" 
                   value="{{newMaterialAmount}}"
                   placeholder="输入用量"
                   bindinput="onAmountInput" />
            <text class="unit">{{getSelectedMaterialUnit()}}</text>
          </view>
          <button class="confirm-add-btn" catchtap="confirmAddMaterial">确认添加</button>
        </view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">操作</view>
    <view class="action-buttons">
      <button class="action-btn" catchtap="editPrice">修改价格</button>
      <button class="action-btn" catchtap="resetSales">重置销量</button>
    </view>
  </view>

  <button class="btn-back" catchtap="goBack">返回</button>
</view>
