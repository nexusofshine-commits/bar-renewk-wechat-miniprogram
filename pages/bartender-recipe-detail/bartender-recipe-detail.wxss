.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
  padding: 20rpx;
}

.header {
  text-align: center;
  padding: 20rpx 0;
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #d4af37;
  margin-bottom: 10rpx;
}

.header-subtitle {
  font-size: 28rpx;
  color: #808080;
}

.section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #d4af37;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
  border-left: 4rpx solid #d4af37;
}

.info-card {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(212, 175, 55, 0.2);
  border-radius: 16rpx;
  padding: 20rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #808080;
}

.info-value {
  font-size: 28rpx;
  color: #ffffff;
}

.info-value.price {
  color: #d4af37;
  font-weight: bold;
}

.info-value.abv {
  color: #ff9800;
  font-weight: bold;
}

.materials-list {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(212, 175, 55, 0.2);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.material-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.material-item:last-child {
  border-bottom: none;
}

.material-name {
  flex: 1;
  font-size: 28rpx;
  color: #ffffff;
}

.material-abv {
  font-size: 22rpx;
  color: #808080;
  margin-left: 10rpx;
}

.material-amount {
  display: flex;
  align-items: center;
  margin: 0 20rpx;
}

.amount-input {
  width: 120rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(212, 175, 55, 0.3);
  border-radius: 8rpx;
  padding: 8rpx;
  color: #d4af37;
  font-size: 28rpx;
}

.unit {
  margin-left: 10rpx;
  color: #808080;
  font-size: 24rpx;
}

.delete-btn {
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  background: rgba(244, 67, 54, 0.2);
  color: #f44336;
  border: none;
}

.add-material-section {
  background: rgba(212, 175, 55, 0.05);
  border: 1px solid rgba(212, 175, 55, 0.2);
  border-radius: 16rpx;
  padding: 20rpx;
}

.add-material-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
  cursor: pointer;
}

.add-material-text {
  font-size: 28rpx;
  color: #d4af37;
}

.arrow {
  font-size: 28rpx;
  color: #d4af37;
}

.material-picker {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1px solid rgba(255, 255, 255, 0.1);
}

.material-picker-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 10rpx;
  border-radius: 8rpx;
  margin-bottom: 10rpx;
  background: rgba(255, 255, 255, 0.03);
}

.material-picker-item.selected {
  background: rgba(212, 175, 55, 0.15);
  border: 1px solid rgba(212, 175, 55, 0.4);
}

.material-picker-text {
  font-size: 28rpx;
  color: #ffffff;
}

.material-picker-abv {
  font-size: 24rpx;
  color: #808080;
  margin-left: 10rpx;
}

.check-mark {
  font-size: 28rpx;
  color: #d4af37;
  font-weight: bold;
}

.amount-input-section {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 8rpx;
}

.amount-input-section .label {
  font-size: 26rpx;
  color: #808080;
}

.amount-input-small {
  width: 120rpx;
  margin: 0 16rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(212, 175, 55, 0.3);
  border-radius: 8rpx;
  padding: 8rpx;
  color: #d4af37;
  font-size: 28rpx;
}

.confirm-add-btn {
  width: 100%;
  margin-top: 20rpx;
  padding: 20rpx;
  background: rgba(212, 175, 55, 0.2);
  border: 1px solid #d4af37;
  color: #d4af37;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.confirm-add-btn::after {
  border: none;
}

.tags-section {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(212, 175, 55, 0.2);
  border-radius: 16rpx;
  padding: 20rpx;
}

.tags-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.tag-item {
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background: rgba(212, 175, 55, 0.15);
  border: 1px solid rgba(212, 175, 55, 0.4);
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #d4af37;
}

.tag-delete {
  margin-left: 10rpx;
  color: #ff9800;
  font-size: 32rpx;
  font-weight: bold;
}

.tag-delete:active {
  color: #f44336;
}

.add-tag-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.tag-input {
  flex: 1;
  padding: 16rpx 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(212, 175, 55, 0.3);
  border-radius: 10rpx;
  font-size: 26rpx;
  color: #ffffff;
}

.tag-add-btn {
  padding: 16rpx 30rpx;
  background: rgba(212, 175, 55, 0.2);
  border: 1px solid #d4af37;
  border-radius: 10rpx;
  font-size: 26rpx;
  color: #d4af37;
}

.tag-add-btn::after {
  border: none;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  padding: 20rpx;
  background: rgba(212, 175, 55, 0.2);
  border: 1px solid rgba(212, 175, 55, 0.5);
  color: #d4af37;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.action-btn::after {
  border: none;
}

.btn-back {
  margin-top: 40rpx;
  background: transparent;
  border: 1px solid #808080;
  color: #808080;
  border-radius: 10rpx;
  font-size: 28rpx;
}

.btn-back::after {
  border: none;
}
