.container {
  height: calc(100vh - 100rpx);
  display: flex;
  flex-direction: column;
  padding: 20rpx;
  box-sizing: border-box;
  background: #1a1a1a;
}

.tab-bar {
  flex-shrink: 0;
  display: flex;
  background: #2f2f2f;
  border-radius: 40rpx;
  padding: 8rpx;
  gap: 8rpx;
  margin-bottom: 20rpx;
}

.tab-item {
  flex: 1;
  padding: 20rpx;
  border-radius: 32rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #808080;
  transition: all 0.3s ease;
}

.tab-item.active {
  background: linear-gradient(135deg, #d4af37 0%, #f0c855 100%);
  color: #1a1a1a;
}

.orders-list {
  flex: 1;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #808080;
}

.order-item {
  padding: 24rpx;
  margin-bottom: 20rpx;
  background: #2f2f2f;
  border-radius: 16rpx;
  border: 2rpx solid rgba(212, 175, 55, 0.2);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.order-time {
  font-size: 24rpx;
  color: #808080;
}

.order-badge {
  padding: 6rpx 16rpx;
  background: #d4af37;
  color: #1a1a1a;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.order-content {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.order-info {
  flex: 1;
  margin-right: 20rpx;
}

.cocktail-name-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.editable-name {
  font-size: 32rpx;
  color: #d4af37;
  font-weight: 600;
  background: transparent;
  border-bottom: 2rpx solid #d4af37;
  padding: 4rpx 0;
}

.cocktail-name {
  font-size: 32rpx;
  color: #d4af37;
  font-weight: 600;
}

.cocktail-name-en {
  font-size: 24rpx;
  color: #808080;
  font-style: italic;
}

.cocktail-description {
  font-size: 26rpx;
  color: #d0d0d0;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.order-price {
  font-size: 32rpx;
  color: #d4af37;
  font-weight: 700;
  flex-shrink: 0;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.user-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
}

.avatar-placeholder {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.user-name {
  font-size: 24rpx;
  color: #d0d0d0;
}

.edit-btn {
  padding: 12rpx 24rpx;
  background: rgba(212, 175, 55, 0.2);
  color: #d4af37;
  border-radius: 20rpx;
  font-size: 24rpx;
}
