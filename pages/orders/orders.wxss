.container {
  height: calc(100vh - 100rpx);
  display: flex;
  flex-direction: column;
  padding: 20rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #0d0d0d 0%, #1a1a1a 50%, #0d0d0d 100%);
  position: relative;
}

.container::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(ellipse at 50% 100%, rgba(212, 175, 55, 0.03) 0%, transparent 50%);
  pointer-events: none;
}

.header-actions {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
  position: relative;
  z-index: 1;
}

.tab-bar {
  flex: 1;
  display: flex;
  background: linear-gradient(145deg, rgba(42, 42, 42, 0.8) 0%, rgba(26, 26, 26, 0.6) 100%);
  border-radius: 40rpx;
  padding: 8rpx;
  gap: 8rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.1);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
}

.tab-item {
  flex: 1;
  padding: 24rpx;
  border-radius: 32rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 400;
  color: #808080;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.tab-item.active {
  background: linear-gradient(135deg, #d4af37 0%, #c9a227 50%, #b8941f 100%);
  color: #0d0d0d;
  font-weight: 600;
  box-shadow: 0 4rpx 15rpx rgba(212, 175, 55, 0.3);
}

.history-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 0 24rpx;
  background: linear-gradient(145deg, rgba(42, 42, 42, 0.8) 0%, rgba(26, 26, 26, 0.6) 100%);
  border-radius: 40rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.2);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
  transition: all 0.3s ease;
}

.history-btn:active {
  background: rgba(212, 175, 55, 0.1);
  border-color: rgba(212, 175, 55, 0.4);
}

.history-icon {
  font-size: 32rpx;
}

.history-text {
  font-size: 24rpx;
  color: #d4af37;
  font-weight: 500;
}

.orders-list {
  flex: 1;
  position: relative;
  z-index: 1;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #666;
  letter-spacing: 2rpx;
}

.order-item {
  padding: 28rpx;
  margin-bottom: 20rpx;
  background: linear-gradient(145deg, rgba(42, 42, 42, 0.8) 0%, rgba(26, 26, 26, 0.6) 100%);
  border-radius: 24rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.1);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
  position: relative;
  overflow: hidden;
}

.order-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 4rpx;
  height: 100%;
  background: linear-gradient(180deg, #d4af37, transparent);
  opacity: 0.5;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
}

.order-time {
  font-size: 24rpx;
  color: #666;
  letter-spacing: 1rpx;
}

.order-badge {
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, rgba(212, 175, 55, 0.2) 0%, rgba(212, 175, 55, 0.1) 100%);
  color: #d4af37;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
  border: 1rpx solid rgba(212, 175, 55, 0.3);
}

.order-content {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
}

.order-info {
  flex: 1;
  margin-right: 20rpx;
}

.cocktail-name-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.editable-name {
  font-size: 34rpx;
  color: #d4af37;
  font-weight: 500;
  background: transparent;
  border-bottom: 2rpx solid #d4af37;
  padding: 8rpx 0;
  min-width: 200rpx;
}

.cocktail-name {
  font-size: 34rpx;
  color: #d4af37;
  font-weight: 500;
  letter-spacing: 1rpx;
}

.cocktail-name-en {
  font-size: 24rpx;
  color: #666;
  font-style: italic;
}

.cocktail-description {
  font-size: 26rpx;
  color: #808080;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.order-price {
  font-size: 32rpx;
  color: #d4af37;
  font-weight: 600;
  padding: 12rpx 24rpx;
  background: rgba(212, 175, 55, 0.1);
  border-radius: 16rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.2);
  flex-shrink: 0;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0 0 16rpx;
  border-top: 1rpx solid rgba(212, 175, 55, 0.1);
}

.user-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(212, 175, 55, 0.3);
}

.avatar-placeholder {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  background: rgba(212, 175, 55, 0.1);
  border-radius: 50%;
  border: 2rpx solid rgba(212, 175, 55, 0.2);
}

.user-name {
  font-size: 26rpx;
  color: #a0a0a0;
}

.edit-btn {
  padding: 16rpx 28rpx;
  background: rgba(212, 175, 55, 0.1);
  color: #d4af37;
  border-radius: 24rpx;
  font-size: 24rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.3);
  transition: all 0.3s ease;
}

.edit-btn:active {
  background: rgba(212, 175, 55, 0.2);
}
