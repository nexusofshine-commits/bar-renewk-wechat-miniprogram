.container {
  height: calc(100vh - 100rpx);
  display: flex;
  flex-direction: column;
  padding: 40rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #0d0d0d 0%, #1a1a1a 50%, #0d0d0d 100%);
  position: relative;
  overflow: hidden;
}

/* 背景装饰 */
.container::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(ellipse at 30% 20%, rgba(212, 175, 55, 0.03) 0%, transparent 50%),
              radial-gradient(ellipse at 70% 80%, rgba(212, 175, 55, 0.02) 0%, transparent 50%);
  pointer-events: none;
}

.welcome-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  position: relative;
  z-index: 1;
}

/* 主图标 - 奢华酒杯 */
.welcome-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
  filter: drop-shadow(0 0 30rpx rgba(212, 175, 55, 0.3));
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

/* 品牌名称 - 奢华字体效果 */
.welcome-title {
  font-size: 64rpx;
  font-weight: 300;
  letter-spacing: 8rpx;
  margin-bottom: 16rpx;
  background: linear-gradient(135deg, #d4af37 0%, #f0d878 30%, #d4af37 60%, #b8941f 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-shadow: 0 0 40rpx rgba(212, 175, 55, 0.2);
}

/* 副标题 */
.welcome-description {
  font-size: 28rpx;
  color: #a0a0a0;
  margin-bottom: 60rpx;
  letter-spacing: 4rpx;
  font-weight: 300;
}

/* 主按钮 - 奢华渐变 */
.btn {
  padding: 32rpx 80rpx;
  font-size: 32rpx;
  border: none;
  border-radius: 50rpx;
  cursor: pointer;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  font-weight: 500;
  letter-spacing: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.5s;
}

.btn:active::before {
  left: 100%;
}

.btn-primary {
  background: linear-gradient(135deg, #d4af37 0%, #c9a227 50%, #b8941f 100%);
  color: #0d0d0d;
  box-shadow: 
    0 8rpx 32rpx rgba(212, 175, 55, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.3);
}

.btn-primary:active {
  transform: translateY(2rpx) scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(212, 175, 55, 0.2);
}

/* 新客福利区域 - 精致卡片 */
.new-customer-offer {
  margin-top: 40rpx;
  padding: 24rpx;
  background: linear-gradient(145deg, rgba(26, 26, 26, 0.8) 0%, rgba(42, 42, 42, 0.6) 100%);
  border-radius: 20rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.2);
  width: 100%;
  box-shadow: 
    0 4rpx 20rpx rgba(0, 0, 0, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(10rpx);
}

.offer-title {
  color: #d4af37;
  font-size: 24rpx;
  margin-bottom: 16rpx;
  text-align: center;
  letter-spacing: 2rpx;
  font-weight: 500;
}

.offer-options {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.offer-option {
  padding: 16rpx 12rpx;
  background: rgba(13, 13, 13, 0.6);
  border-radius: 12rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.1);
  transition: all 0.3s ease;
  text-align: center;
}

.offer-option:active {
  border-color: rgba(212, 175, 55, 0.4);
  background: rgba(212, 175, 55, 0.05);
}

.offer-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
  display: block;
}

.offer-label {
  font-weight: 500;
  color: #d4af37;
  font-size: 22rpx;
  margin-bottom: 4rpx;
  display: block;
}

.offer-description {
  font-size: 18rpx;
  color: #666;
  line-height: 1.3;
}

/* 装饰线条 */
.decorative-line {
  width: 60rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #d4af37, transparent);
  margin: 20rpx auto;
}
