.container {
  height: calc(100vh - 100rpx);
  display: flex;
  flex-direction: column;
  padding: 30rpx;
  box-sizing: border-box;
  background: #1a1a1a;
}

.welcome-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.welcome-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.welcome-title {
  font-size: 56rpx;
  color: #d4af37;
  font-weight: 700;
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

.welcome-description {
  font-size: 28rpx;
  color: #d0d0d0;
  margin-bottom: 40rpx;
}

.btn {
  padding: 24rpx 60rpx;
  font-size: 30rpx;
  border: none;
  border-radius: 40rpx;
  cursor: pointer;
  transition: all 0.3s ease;
  font-weight: 600;
  letter-spacing: 2rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary {
  background: linear-gradient(135deg, #d4af37 0%, #f0c855 100%);
  color: #1a1a1a;
}

.new-customer-offer {
  margin-top: 30rpx;
  padding: 20rpx;
  background: #2f2f2f;
  border-radius: 16rpx;
  border: 2rpx solid rgba(212, 175, 55, 0.3);
  width: 100%;
}

.offer-title {
  color: #d4af37;
  font-size: 28rpx;
  margin-bottom: 16rpx;
  text-align: center;
}

.offer-options {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.offer-option {
  padding: 16rpx;
  background: #252525;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
  text-align: center;
}

.offer-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.offer-label {
  font-weight: 600;
  color: #d4af37;
  font-size: 24rpx;
  margin-bottom: 4rpx;
}

.offer-description {
  font-size: 22rpx;
  color: #808080;
}
