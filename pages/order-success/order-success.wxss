.container {
  height: calc(100vh - 100rpx);
  display: flex;
  flex-direction: column;
  padding: 60rpx 40rpx;
  background: linear-gradient(180deg, #0d0d0d 0%, #1a1a1a 50%, #0d0d0d 100%);
  position: relative;
}

.container::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: 
    radial-gradient(ellipse at 50% 0%, rgba(212, 175, 55, 0.1) 0%, transparent 50%),
    radial-gradient(ellipse at 50% 100%, rgba(212, 175, 55, 0.05) 0%, transparent 50%);
  pointer-events: none;
}

.success-icon {
  font-size: 120rpx;
  text-align: center;
  margin-bottom: 30rpx;
  animation: bounce 1s ease-in-out;
}

@keyframes bounce {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.success-title {
  font-size: 56rpx;
  font-weight: 300;
  text-align: center;
  background: linear-gradient(135deg, #d4af37 0%, #f0d878 50%, #d4af37 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 6rpx;
  margin-bottom: 16rpx;
}

.success-subtitle {
  font-size: 28rpx;
  color: #808080;
  text-align: center;
  margin-bottom: 50rpx;
  letter-spacing: 2rpx;
}

.alcohol-card {
  background: linear-gradient(145deg, rgba(42, 42, 42, 0.9) 0%, rgba(26, 26, 26, 0.7) 100%);
  border-radius: 28rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.3);
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
}

.alcohol-title {
  font-size: 28rpx;
  color: #808080;
  text-align: center;
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
}

.alcohol-value {
  font-size: 72rpx;
  font-weight: 300;
  text-align: center;
  background: linear-gradient(135deg, #d4af37 0%, #f0d878 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 4rpx;
  margin-bottom: 20rpx;
}

.alcohol-tip {
  font-size: 24rpx;
  color: #666;
  text-align: center;
}

.ranking-section {
  flex: 1;
  background: linear-gradient(145deg, rgba(42, 42, 42, 0.7) 0%, rgba(26, 26, 26, 0.5) 100%);
  border-radius: 28rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.1);
}

.section-title {
  font-size: 32rpx;
  color: #d4af37;
  text-align: center;
  font-weight: 500;
  letter-spacing: 2rpx;
  margin-bottom: 30rpx;
}

.ranking-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.ranking-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: rgba(13, 13, 13, 0.5);
  border-radius: 20rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.1);
  transition: all 0.3s ease;
}

.ranking-item:nth-child(1) {
  border-color: rgba(212, 175, 55, 0.5);
  background: rgba(212, 175, 55, 0.1);
}

.ranking-item:nth-child(2) {
  border-color: rgba(212, 175, 55, 0.3);
  background: rgba(212, 175, 55, 0.05);
}

.ranking-item:nth-child(3) {
  border-color: rgba(212, 175, 55, 0.2);
  background: rgba(212, 175, 55, 0.03);
}

.ranking-number {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, rgba(42, 42, 42, 1) 0%, rgba(26, 26, 26, 1) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #808080;
  margin-right: 20rpx;
}

.ranking-item:nth-child(1) .ranking-number {
  background: linear-gradient(135deg, #d4af37 0%, #f0d878 100%);
  color: #0d0d0d;
  box-shadow: 0 4rpx 20rpx rgba(212, 175, 55, 0.4);
}

.ranking-item:nth-child(2) .ranking-number {
  background: linear-gradient(135deg, #c0c0c0 0%, #d4d4d4 100%);
  color: #0d0d0d;
  box-shadow: 0 4rpx 15rpx rgba(192, 192, 192, 0.3);
}

.ranking-item:nth-child(3) .ranking-number {
  background: linear-gradient(135deg, #cd7f32 0%, #daa520 100%);
  color: #0d0d0d;
  box-shadow: 0 4rpx 10rpx rgba(205, 127, 50, 0.3);
}

.user-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(212, 175, 55, 0.2);
  margin-right: 20rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 28rpx;
  color: #fff;
  font-weight: 400;
  margin-bottom: 8rpx;
}

.user-count {
  font-size: 24rpx;
  color: #d4af37;
  font-weight: 600;
}

.user-alcohol {
  font-size: 24rpx;
  color: #808080;
  padding: 8rpx 16rpx;
  background: rgba(212, 175, 55, 0.1);
  border-radius: 20rpx;
}

.bottom-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  padding: 32rpx;
  border-radius: 40rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.action-btn.primary {
  background: linear-gradient(135deg, #d4af37 0%, #c9a227 50%, #b8941f 100%);
  color: #0d0d0d;
  box-shadow: 0 8rpx 30rpx rgba(212, 175, 55, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.3);
}

.action-btn.primary:active {
  transform: translateY(2rpx) scale(0.98);
  box-shadow: 0 4rpx 15rpx rgba(212, 175, 55, 0.2);
}

.action-btn.secondary {
  background: transparent;
  color: #a0a0a0;
  border: 2rpx solid rgba(160, 160, 160, 0.3);
}

.action-btn.secondary:active {
  border-color: #d4af37;
  color: #d4af37;
  background: rgba(212, 175, 55, 0.05);
}
